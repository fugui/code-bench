:80 {
                                          
    # 静态根目录指向主 Portal 编译出的物理路径
    root * /home/fugui/codes/code-bench/dist
    # ────────────────────────────────────────────────────────
    # 1. 专门接收子应用静态资源，直接反代（没有任何 try_files 抢跑，100% 安全）
    # ────────────────────────────────────────────────────────
    handle /shield/assets/* {
        reverse_proxy localhost:8080
    }
    # ────────────────────────────────────────────────────────
    # 2. 专门接收子应用 API 接口，直接反代（没有任何 try_files 抢跑，100% 安全）
    # ────────────────────────────────────────────────────────
    handle /shield/api/* {
        reverse_proxy localhost:8080
    }
    # ────────────────────────────────────────────────────────
    # 3. 拦截子应用的页面刷新请求（如 /shield/tasks），重写为 /index.html 返回给基座
    # ────────────────────────────────────────────────────────
    handle /shield* {
        rewrite * /index.html
        file_server
    }
    # ────────────────────────────────────────────────────────
    # 4. 其它所有主 Portal 站点的正常请求（防刷新 404 兜底）
    # ────────────────────────────────────────────────────────
    handle {
        try_files {path} /index.html
        file_server
    }
}
